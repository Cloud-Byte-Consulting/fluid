{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Cloud-Byte-Consulting/fluid/main/spec/dagspec.schema.json",
  "title": "Fluid DagSpec",
  "description": "A workflow DAG of agent nodes. Nodes without dependencies run concurrently; a node runs when every id in dependsOn has completed, receiving those nodes' outputs as inputs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "nodes", "caps"],
  "properties": {
    "version": { "type": "string", "description": "Contract version. Use \"1\"." },
    "name": { "type": "string", "description": "Human-readable workflow name." },
    "defaultModel": { "type": "string", "description": "\"provider:model\" used by nodes that do not set model." },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "caps": { "$ref": "#/$defs/caps" }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "instructions"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,64}$", "description": "Unique node id." },
        "instructions": { "type": "string", "description": "What this agent node must do." },
        "model": { "type": "string", "description": "\"provider:model\" override for this node." },
        "tools": { "type": "array", "items": { "type": "string" }, "description": "Tool allowlist (reserved)." },
        "dependsOn": { "type": "array", "items": { "type": "string" }, "description": "Ids of nodes whose outputs this node consumes." },
        "outputSchema": { "type": "object", "description": "JSON Schema the node's output must satisfy." }
      }
    },
    "caps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxNodes", "maxRounds", "maxConcurrent", "tokenBudget"],
      "properties": {
        "maxNodes": { "type": "integer", "minimum": 1, "description": "Maximum nodes in the DAG." },
        "maxRounds": { "type": "integer", "minimum": 1, "description": "Maximum attempts per node." },
        "maxConcurrent": { "type": "integer", "minimum": 1, "description": "Maximum nodes in flight at once." },
        "tokenBudget": { "type": "integer", "minimum": 1, "description": "Run-wide token ceiling; dispatch stops at or above it." }
      }
    }
  }
}
